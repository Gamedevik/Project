<?xml version="1.0" encoding="utf-8"?>
<!-- Фон для полей ввода - серый прямоугольник со скругленными углами -->
<shape xmlns:android="http://schemas.android.com/apk/res/android">
    <solid android:color="#F5F5F5" />      <!-- Цвет фона -->
    <corners android:radius="8dp" />       <!-- Скругление углов -->
    <stroke
        android:width="1dp"
        android:color="#E0E0E0" />         <!-- Рамка -->
</shape>